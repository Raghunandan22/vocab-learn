// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LanguageLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

// User model for authentication
model User {
  id                String        @id @default(cuid())
  email             String        @unique
  passwordHash      String
  name              String?
  nativeLanguage    String        @default("en")
  targetLanguage    String        @default("fr")
  proficiencyLevel  LanguageLevel @default(A1)
  vocabLists        VocabList[]
  savedWords        SavedWord[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([email])
}

// Vocabulary list from a specific movie/episode
model VocabList {
  id               String        @id @default(cuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  movieTitle       String
  language         String        @default("fr")
  words            VocabWord[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([userId, movieTitle])
  @@index([userId])
  @@index([movieTitle])
}

// Individual vocabulary word
model VocabWord {
  id           String        @id @default(cuid())
  vocabListId  String
  vocabList    VocabList     @relation(fields: [vocabListId], references: [id], onDelete: Cascade)
  word         String
  wordLower    String
  translation  String
  frequency    Int           @default(1)
  level        String        @default("Intermediate")
  example      String?
  createdAt    DateTime      @default(now())

  @@unique([vocabListId, wordLower])
  @@index([vocabListId])
}

// Words saved by user for flashcard practice
model SavedWord {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  word           String
  language       String    @default("fr")
  translation    String
  example        String?
  level          String    @default("Intermediate")
  reviewCount    Int       @default(0)
  lastReviewedAt DateTime?
  nextReviewAt   DateTime?
  aiExamples     String?   // JSON-encoded string[] of AI-generated examples
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, word, language])
  @@index([userId])
  @@index([userId, nextReviewAt])
}
